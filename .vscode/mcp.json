{
  "servers": {
    "hello-world": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "python",
        "server.py"
      ]
    },
    "aladdin-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "aladdin",
        "aladdin-mcp"
      ],
      "env": {
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}
